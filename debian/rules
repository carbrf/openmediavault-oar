#!/usr/bin/make -f

# Uncomment this to turn on verbose mode.
#export DH_VERBOSE=1

%:
	dh $@ --with python3

# Enable + daemon-reload the finalize units, but do not start them at
# install time: omv-oar-finalize.service runs at boot and the
# omv-oar-finalize@.service instances are started on demand.
override_dh_installsystemd:
	dh_installsystemd --no-start

# Never ship bytecode caches; dh_python3 recompiles the modules under
# dist-packages on the target at install time.
execute_after_dh_install:
	find debian/openmediavault-oar -depth -type d -name __pycache__ -exec rm -rf {} +
