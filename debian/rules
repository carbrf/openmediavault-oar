#!/usr/bin/make -f

# Uncomment this to turn on verbose mode.
#export DH_VERBOSE=1

%:
	dh $@ --with python3

# The finalize units are enabled and daemon-reloaded from the maintainer
# scripts (postinst/postrm). dh_installsystemd does not pick up units
# installed under /usr/lib/systemd/system in this debhelper, so disable
# it explicitly to avoid partial/duplicate snippets.
override_dh_installsystemd:

# Never ship bytecode caches; dh_python3 recompiles the modules under
# dist-packages on the target at install time.
execute_after_dh_install:
	find debian/openmediavault-oar -depth -type d -name __pycache__ -exec rm -rf {} +
